     C_pCPNRnac1 C_pRS_MOT1 C_pMID_MOT1 C_pC_FAMTHR C_pC_NEIGHTHT C_pC_HRSHSES; 
MISSING=.;




usevariables are 

!PARENTING 
pFacc_RS 
!INTERNALIZING PROBLEMS
pINTPRT1 
pINTPRT3 
!COVARIATES
!MODERATORS 
SalLamy1 
!DEFINED VARIABLES 
L_Fint
;

WEIGHT=ppensity;
CLUSTER IS familyid;
STRATIFICATION = SCANNER;

DEFINE:

L_Fint = (SalLamy1*pFacc_RS); !pFacc_RS

ANALYSIS:
TYPE=COMPLEX;
ESTIMATOR=MLR;

Model:

! A PATH 

pINTPRT3 ON 
  pINTPRT1
  pFacc_RS (b1)
  SalLamy1 (b2)
  L_Fint (b3);

! T1 covariances
L_Fint WITH pFacc_RS SalLamy1;
pFacc_RS WITH SalLamy1;

! MEANS AND VARIANCES 
pINTPRT1
pFacc_RS
SalLamy1
L_Fint 
;

[
pINTPRT1
pFacc_RS
SalLamy1
L_Fint 
];


MODEL CONSTRAINT:
NEW(
  slope_low slope_mean slope_high
  int_low int_mean int_high
);

! Slopes (partial derivatives of Y w.r.t. X at each Z level)
slope_low  = b1 + b3 * (-0.227);
slope_mean = b1 + b3 * (0.013);
slope_high = b1 + b3 * (0.257);

! Intercepts (b0 + b2*Z)
int_low  = b2 * (-0.227);
int_mean = b2 * (0.013);
int_high = b2 * (0.257);


output: stdyx tech1 tech3 tech4 tech8 CINTERVAL;!(BCBOOTSTRAP);! MODINDICES (ALL);


