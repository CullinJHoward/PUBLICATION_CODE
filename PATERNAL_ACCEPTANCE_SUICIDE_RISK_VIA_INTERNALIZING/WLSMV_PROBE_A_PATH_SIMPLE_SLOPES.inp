     C_pDMN_NA1 C_pDMNSAL1 C_pDMNVAN1 C_pCONFPN1 C_pCPNFPN1 C_pFPNFPN1 C_pFPNLnac1
     C_pFPNRnac1 C_pFPNLamy1 C_pFPNRamy1 C_pSALLnac1 C_pSALRnac1 C_pDMNLnac1
