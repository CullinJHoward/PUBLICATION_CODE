!INTERNALIZING PROBLEMS
pINTPRT1 
pINTPRT3 
!COVARIATES
pyage1
pyage3 
!pyage5
ysex 
pincome
!MODERATORS 
pSNLamyRS 
pSNRamyRS
!pSNLnaccRS 
!pSNRnaccRS
!DEFINED VARIABLES 
L_Fint
L_Mint
R_Fint
R_Mint
;

CATEGORICAL IS
 SLF_HRM_CHA 
 SUI_ID_CHA; 

WEIGHT=ppensity;
CLUSTER IS familyid;
STRATIFICATION = SCANNER;

DEFINE:

L_Fint = (pSNLamyRS*pFacc_RS)/100; !pFacc_RS
L_Mint = (pSNLamyRS*C_pM_acc_M1)/100;
R_Fint = (pSNRamyRS*pFacc_RS)/100;
R_Mint = (pSNRamyRS*C_pM_acc_M1)/100;

ANALYSIS:
TYPE=COMPLEX;
ESTIMATOR=WLSMV;
!BOOTSTRAP = 5000;

Model:

! A PATH 

pINTPRT3 ON 
pINTPRT1
SUI_ID_1 
SLF_HRM_1
pyage1  
pyage3
ysex
pincome
pFacc_RS(gamma1)
C_pM_acc_M1
pSNLamyRS 
pSNRamyRS
L_Fint (gamma2)
L_Mint
R_Fint
R_Mint
; 

! T1 covariances
pFacc_RS WITH C_pM_acc_M1;
pSNLamyRS WITH pSNRamyRS;

!T3/T5 Suicidal RISK  

SUI_ID_CHA ON 
pINTPRT1
pINTPRT3 (b1)
SUI_ID_1 
SLF_HRM_1
pyage1  
pyage3
ysex
pincome
