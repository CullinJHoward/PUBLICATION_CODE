!MODEL CONSTRAINT:
!PLOT(indirect);
!LOOP(C_pC_dmn_dmn_W1,-.31, .69, 0.001);
!indirect = b1*(gamma1+gamma2*C_pC_dmn_dmn_W1);
!PLOT:TYPE = PLOT2;

MODEL CONSTRAINT:
NEW(FacLLzSI, FacLzSI, FacmzSI, FacHzSI, FacHHzSI,
    FacLLzSH, FacLzSH, FacmzSH, FacHzSH, FacHHzSH);

! PICK A POINT
FacLLzSI = b1 * (gamma1 + gamma2 * (-30));     ! At -2 SD
FacLzSI = b1 * (gamma1 + gamma2 * (-15)); ! At -1 SD
FacmzSI = b1 * (gamma1+ gamma2 * (0));       ! At mean (0)
FacHzSI = b1 * (gamma1 + gamma2 * (15));     ! At +1 SD
FacHHzSI = b1 * (gamma1 + gamma2 * (30)); ! At +2 SD

FacLLzSH = b2 * (gamma1 + gamma2 * (-30));     ! At +1 SD
FacLzSH = b2 * (gamma1 + gamma2 * (-15)); ! At -1 SD
FacmzSH = b2 * (gamma1+ gamma2 * (0));       ! At mean (0)
FacHzSH = b2 * (gamma1 + gamma2 * (15));     ! At +1 SD
FacHHzSH = b2 * (gamma1 + gamma2 * (30)); ! At -1 SD



output: stdyx tech1 tech3 tech4 tech8 CINTERVAL;!(BCBOOTSTRAP);! MODINDICES (ALL);


