     TOT_P_1 TOT_P_2 TOT_Y_1 TOT_Y_2 P_CTQ1 P_CTQ2 P_CTQ3 P_CTQ4 P_CTQ5 P_CTQ6
     P_CTQ7 P_CTQ8 P_CTQ9 P_CTQ10 P_CTQ11 P_CTQ12 P_CTQ13 P_CTQ14 P_CTQ15 P_CTQ16
