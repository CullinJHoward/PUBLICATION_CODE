USEVARIABLES = 
!TIME 1
INT_P_1
EXT_P_1
SOC_P_1
THO_P_1
ATT_P_1
!TIME 2
INT_P_2
EXT_P_2
SOC_P_2
THO_P_2
ATT_P_2;

IDVARIABLE = ID;

ANALYSIS: 

ESTIMATOR = MLR;

MODEL:

PFACTOR_1 BY 
SOC_P_1 (L1)
EXT_P_1 (L2)
INT_P_1 (L3)
THO_P_1 !(L4)
ATT_P_1 (L5)
;

PFACTOR_2 BY 
SOC_P_2 (L1)
EXT_P_2 (L2)
INT_P_2 (L3)
THO_P_2 !(L4)
ATT_P_2 (L5)
;

!Estimate Latent Means;
[PFACTOR_1] ;
[PFACTOR_2] ;

!Fix first intercept to 0 at each time for the marker method;
[SOC_P_1@0] (T1);
[SOC_P_2@0] (T1);

!Labels constain additinal intercepts to be equal across time;
[EXT_P_1] (T2);
[EXT_P_2] (T2);
[INT_P_1] ;!(T3);
[INT_P_2] ;!(T3);
[THO_P_1] (T4);
[THO_P_2] (T4);
[ATT_P_1] (T5);
[ATT_P_2] (T5);

!Constrain residuals to be equal across time;
SOC_P_1 (R1);
SOC_P_2 (R1);
EXT_P_1 (R2);
EXT_P_2 (R2);
INT_P_1 (R3);
INT_P_2 (R3);
THO_P_1 (R4);
THO_P_2 (R4);
ATT_P_1 (R5);
ATT_P_2 (R5);

!allows correlated residuals across time;
INT_P_1 WITH INT_P_2;
EXT_P_1 WITH EXT_P_2;
SOC_P_1 WITH SOC_P_2;
THO_P_1 WITH THO_P_2;
ATT_P_1 WITH ATT_P_2;


!SAVEDATA: FILE = P_FACTOR_JOINT.txt;
!SAVE = FSCORES;


OUTPUT: SAMPSTAT STAND MODINDICES (3.00) TECH4;